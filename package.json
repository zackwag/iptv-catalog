{
  "name": "iptv-catalog-api",
  "version": "1.0.7",
  "description": "TypeScript API for browsing the iptv-org catalog and exporting curated M3U/EPG playlists for Channels DVR",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:local": "tsc && npm run build --prefix frontend && cp -r frontend/dist public",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.1",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.11",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
